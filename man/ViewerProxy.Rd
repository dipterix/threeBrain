    \if{html}{\out{<div class="arguments">}}
    \describe{
      \item{\code{id}}{Character scalar: stable decoration ID.}
      \item{\code{text}}{Character scalar: label to display.}
      \item{\code{position}}{Numeric vector of length 3 in world space.}
      \item{\code{font_size}}{Positive number: world-space sprite height (mm).}
      \item{\code{color}}{CSS color string (e.g. \code{"#ff0000"}).}
      \item{\code{layer}}{Integer or integer vector: camera layer(s).}
    }
    \if{html}{\out{</div>}}
  }
}

